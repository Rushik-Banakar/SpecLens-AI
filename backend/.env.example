# Server Host and Port
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google Gemini API Keys
GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq API Keys & Model Configuration
GROQ_API_KEY_1=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API Keys & Model Configuration
OPENROUTER_API_KEY_1=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
